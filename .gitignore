# Create a comprehensive .gitignore
cat > .gitignore << 'EOF'
# Local .terraform directories
**/.terraform/

# .tfstate files
*.tfstate
*.tfstate.*

# Crash log files
crash.log
*crash.log

# Exclude all .tfvars files
*.tfvars
*.tfvars.json

# Ignore override files
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# Terraform plan files
*.tfplan

# CLI configuration files
.terraformrc
terraform.rc

# Terragrunt cache
.terragrunt-cache/

# Lock files
.terraform.lock.hcl

# IDE files
.vscode/
.idea/
*.swp
*.swo

# OS files
.DS_Store
Thumbs.db

# Log files
*.log

# Temporary files
tmp/
temp/
EOF
